{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [{"expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{endpoint}} {{status}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Request Duration p95",
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "Active Requests",
      "targets": [{"expr": "http_requests_active"}],
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8}
    },
    {
      "type": "stat",
      "title": "Rate Limited",
      "targets": [{"expr": "increase(rate_limit_blocked_total[5m])"}],
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8}
    }
  ],
  "schemaVersion": 39,
  "title": "STL Forge Metrics",
  "version": 1
}
